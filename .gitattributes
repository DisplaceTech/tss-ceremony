*.js text eol=lf
*.ts text eol=lf
*.jsx text eol=lf
*.tsx text eol=lf
*.css text eol=lf
*.scss text eol=lf
*.less text eol=lf
*.html text eol=lf
*.xml text eol=lf
*.sql text eol=lf
*.graphql text eol=lf
*.proto text eol=lf
*.dockerfile text eol=lf
Dockerfile text eol=lf
Makefile text eol=lf
*.make text eol=lf
.gitignore text eol=lf
.gitattributes text eol=lf
.gitmodules text eol=lf
LICENSE text eol=lf

