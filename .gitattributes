# Git attributes for line ending handling and binary files

# Text files - use LF line endings on all platforms
*.go text eol=lf
*.md text eol=lf
*.txt text eol=lf
*.json text eol=lf
*.yaml text eol=lf
*.yml text eol=lf
*.toml text eol=lf
*.sh text eol=lf
*.bash text eol=lf
*.fish text eol=lf
*.zsh text eol=lf
*.ps1 text eol=lf
