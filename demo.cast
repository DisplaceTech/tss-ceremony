[15.147379, "o", "\u001b[H\u001b[35m  k_b \u001b[0mdab2d5ac 60bb05d3 76e0f8c8 9d765afa 31fef480 03884a79 1eb4146a f225a0e4\u001b[38;5;241m  random\u001b[0m\u001b[K\r\n\u001b[36m  R_a\u001b[0m\u001b[38;5;241m = k_a·G = \u001b[0mb5f0404f a6359859 a72028a5 c2def4c1 c91f54c8 ffa07280 ace9bed8 2ad11d08\u001b[K\r\n\u001b[35m  R_b\u001b[0m\u001b[38;5;241m = k_b·G = \u001b[0ma6eb4979 aa4cea12 4e62b7f4 aa697910 0ecfe7b6 f505c7aa 40965eba 8201822a\u001b[K\r\n\u001b[33m  R  \u001b[0m\u001b[38;5;241m = R_a + R_b = \u001b[0ma91b6be9 7a497f8e c60df3c0 8869f2e7 0426d4da 676ae0a7 c7668579 35a80233\u001b[K\r\n\u001b[33m  r  \u001b[0m\u001b[38;5;241m = R.x mod n = \u001b[0ma91b6be9 7a497f8e c60df3c0 8869f2e7 0426d4da 676ae0a7 c7668579 35a80233\u001b[K\r\n\u001b[K\r\n\u001b[1m  ─── Oblivious Transfer \u001b[0m\u001b[38;5;241m──────────────────────────────────────────────────────────────────────────────────────────────\u001b[0m\u001b[K\r\n\u001b[38;5;241m  sender:   \u001b[0mx₀ = 36ff7b15 59495489 752691c3 c7c8332b…\u001b[38;5;241m  random\u001b[0m\u001b[K\r\n\u001b[38;5;241m            \u001b[0mx₁ = 27770f20 285cd1ec 4bbd3902 14bdc513…\u001b[38;5;241m  random\u001b[0m\u001b[K\r\n\u001b[38;5;241m  receiver: \u001b[0mc  = 0\u001b[K\r\n\u001b[38;5;241m            \u001b[0mx_c = 36ff7b15 59495489 752691c3 c7c8332b…\u001b[K\r\n\u001b[K\r\n\u001b[1m  ─── Multiplicative to Additive \u001b[0m\u001b[38;5;241m──────────────────────────────────────────────────────────────────────────────────────\u001b[0m\u001b[K\r\n\u001b[38;5;241m  product = k_a · k_b mod n\u001b[0m\u001b[K\r\n\u001b[38;5;241m  β = random scalar in [1, n-1]\u001b[0m\u001b[K\r\n\u001b[38;5;241m  α = product - β mod n\u001b[0m\u001b[K\r\n\u001b[38;5;241m  so α + β ≡ k_a · k_b  (mod n)\u001b[0m\u001b[K\r\n\u001b[36m  α \u001b[0m921be796 208347a8 0cf66f55 9d614dab 7c180220 00069326 f6c110e2 a4addeed\u001b[K\r\n\u001b[35m  β \u001b[0m3376048d b442a80f 8e93bdc1 07d37a8f 8c26ccba 2ed169f2 0547c1b9 3360536d\u001b[K\r\n\u001b[K\r\n\u001