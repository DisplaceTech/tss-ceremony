[15.479947, "o", "\u001b[H\u001b[1m  ─── Combine \u001b[0m\u001b[38;5;241m─────────────────────────────────────────────────────────────────────────────────────────────────────────\u001b[0m\u001b[K\r\n\u001b[33m  s\u001b[0m\u001b[38;5;241m = s_a + s_b mod n\u001b[0m\u001b[K\r\n    4a1967d8 d1769d08 e2833d78 97cf179f c9426850 73f89ece becb8f83 2d1b8b60\u001b[K\r\n\u001b[K\r\n\u001b[1m  ─── Signature \u001b[0m\u001b[38;5;241m───────────────────────────────────────────────────────────────────────────────────────────────────────\u001b[0m\u001b[K\r\n\u001b[33m  r \u001b[0ma91b6be9 7a497f8e c60df3c0 8869f2e7 0426d4da 676ae0a7 c7668579 35a80233\u001b[K\r\n\u001b[33m  s \u001b[0m4a1967d8 d1769d08 e2833d78 97cf179f c9426850 73f89ece becb8f83 2d1b8b60\u001b[K\r\n\u001b[K\r\n  ECDSA.Verify(P, H(m), r, s) → \u001b[32m✓ VALID\u001b[0m\u001b[K\r\n\n\u001b[38;5;241m  The signature (r, s) is valid under combined key P.\u001b[0m\u001b[K\r\n\u001b[38;5;241m  No single party ever held the private key p.\u001b[0m\u001b[K\r\n\u001b[K\r\n\u001b[1m  ─── Verify with OpenSSL \u001b[0m\u001b[38;5;241m─────────────────────────────────────────────────────────────────────────────────────────────\u001b[0m\u001b[K\r\n\u001b[38;5;241m  OpenSSL needs DER-encoded inputs. Here's how our values map:\u001b[0m\u001b[K\r\n\n\u001b[38;5;241m  message: \u001b[0m\u001b[32m\"Hello, threshold signatures\"\u001b[0m\u001b[K\r\n\u001b[K\r\n\u001b[38;5;241m  public key (DER):\u001b[0m\u001b[K\r\n\u001b[38;5;241m    3056 3010                          \u001b[0m\u001b[38;5;241mSEQUENCE { SEQUENCE {\u001b[0m\u001b[K\r\n\u001b[38;5;241m      0607 2a8648ce3d0201              \u001b[0m\u001b[38;5;241mOID ecPublicKey\u001b[0m\u001b[K\r\n\u001b[38;5;241m      0605 2b8104000a                  \u001b[0m\u001b[38;5;241mOID secp256k1 }\u001b[0m\u001b[K\r\n\u001b[38;5;241m    034200 04                          \u001b[0m\u001b[38;5;241mBIT STRING, uncompressed point\u001b[0m\u001b[K\r\n    \u001b[36mP.x  \u001b[0m\u001b[36mf9308a01 9258c310 49344f85 f89d5229 b531c845 836f99b0 8601f113 bce036f9\u001b[0m\u001b[K\r\n    \u001b[35mP.y  \u001b[0m\u001b[35m388f7b0f 632de814 0fe337e6 2a37f356 6500a999 34c2231b 6cb9fd75 84b8e672\u001b[0m\u001b[K\r\n\u001b[K\r\n\u001b[38;5;241m  signature (DER):\u001b[0m\u001b[K\r\n\u001b[38;5;241m    30 <len>                            \u001b[0m\u001b[38;5;241mSEQUENCE {\u001b[0m\u001b[K\r\n\u001b[38;5;241m      02 <len>                          \u001b[0m\u001b[38;5;241mINTEGER r\u001b[0m\u001b[K\r\n      \u001b[33mr  \u001b[0m\u001b[33ma91b6be9 7a497f8e c60df3c0 8869f2e7 0426d4da 676ae0a7 c7668579 35a80233\u001b[0m\u001b[K\r\n\u001b[38;5;241m      02 <len>                          \u001b[0m\u001b[38;5;241mINTEGER s }\u001b[0m\u001b[K\r\n      \u001b[33ms  \u001b[0m\u001b[33m4a1967d8 d1769d08 e2833d78 97cf179f c9426850 73f89ece becb8f83 2d1b8b60\u001b[0m\u001b[K\r\n\u001b[K\r\n\u001b[38;5;241m  echo -n '\u001b[0m\u001b[32mHello, threshold signatures\u001b[0m\u001b[38;5;241m' | \\\u001b[0m\u001b[K\r\n\u001b[38;5;241m      openssl dgst -sha256 \\\u001b[0m\u001b[K\r\n\u001b[38;5;241m      -verify <(echo '\u001b[0m\u001b[38;5;241m3056301006072a8648ce3d020106052b8104000a03420004\u001b[0m\u001b[36mf9308a019258c31049344f85f89d5229b531c845836f99b086\u001b[0m\u001b[35m\u001b[0m\u001b[38;5;241m\u001b[0m\r\n\u001b[38;5;241m        xxd -r -p | openssl ec -pubin -inform DER 2>/dev/null) \\\u001b[0m\u001b[K\r\n\u001b[38;5;241m      -signature <(echo '\u001b[0m\u001b[38;5;241m30450221\u001b[0m\u001b[33m00a91b6be97a497f8ec60df3c08869f2e70426d4da676ae0a7c766857935a80233\u001b[0m\u001b[38;5;241m0220\u001b[0m\u001b[33m4a1967d8d1769d08e\u001b[0m\u001b[38;5;241m\u001b[0m\r\n\n\u001b[40;H"]
