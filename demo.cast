[12.430729, "o", "\u001b[H\u001b[38;5;241m  ════════════════════════════════════════════════════════════════════════════════════════════════════════════════════\u001b[0m\u001b[K\r\n\u001b[K\r\n\u001b[1m  ─── Key Generation \u001b[0m\u001b[38;5;241m──────────────────────────────────────────────────────────────────────────────────────────────────\u001b[0m\u001b[K\r\n\u001b[36m  a \u001b[0m00000000 00000000 00000000 00000000 00000000 00000000 00000000 00000001\u001b[38;5;241m  Party A secret\u001b[0m\u001b[K\r\n\u001b[35m  b \u001b[0m00000000 00000000 00000000 00000000 00000000 00000000 00000000 00000002\u001b[38;5;241m  Party B secret\u001b[0m\u001b[K\r\n\u001b[36m  A\u001b[0m\u001b[38;5;241m = a·G\u001b[0m\u001b[K\r\n    79be667e f9dcbbac 55a06295 ce870b07 029bfcdb 2dce28d9 59f2815b 16f81798\u001b[38;5;241m  Party A public\u001b[0m\u001b[K\r\n\u001b[35m  B\u001b[0m\u001b[38;5;241m = b·G\u001b[0m\u001b[K\r\n    c6047f94 41ed7d6d 3045406e 95c07cd8 5c778e4b 8cef3ca7 abac09b9 5c709ee5\u001b[38;5;241m  Party B public\u001b[0m\u001b[K\r\n\u001b[33m  P\u001b[0m\u001b[38;5;241m = A + B\u001b[0m\u001b[31m  ← no one knows p where P = p·G\u001b[0m\u001b[K\r\n    f9308a01 9258c310 49344f85 f89d5229 b531c845 836f99b0 8601f113 bce036f9\u001b[K\r\n\u001b[K\r\n\u001b[1m  ─── Signing \u001b[0m\u001b[38;5;241m─────────────────────────────────────────────────────────────────────────────────────────────────────────\u001b[0m\u001b[K\r\n\u001b[38;5;241m  m \u001b[0m\"Hello, threshold signatures\"\u001b[K\r\n\u001b[38;5;241m  H = SHA-256(m)\u001b[0m\u001b[K\r\n    deed21f8 e35c13df 92568023 3a2ad23f ce6ef7b2 c9be7b70 67789844 ca3fa105\u001b[K\r\n\u001b[K\r\n\u001b[1m  ─── Nonces \u001b[0m\u001b[38;5;241m──────────────────────────────────────────────────────────────────────────────────────────────────────────\u001b[0m\u001b[K\r\n\u001b[36m  k_a \u001b[0mb1a16fdf d1406019 9f6e810f f0c21064 8af4f496 0847f3ff fa47d888 ee42ad3c\u001b[38;5;241m  random\u001b[0m\u001b[K\r\n\u001b[35m  k_b \u001b[0mdab2d5ac 60bb05d3 76e0f8c8 9d765afa 31fef480 03884a79 1eb4146a f225a0e4\u001b[38;5;241m  random\u001b[0m\u001b[K\r\n\u001b[36m  R_a\u001b[0m\u001b[38;5;241m = k_a·G = \u001b[0mb5f0404f a6359859 a72028a5 c2def4c1 c91f54c8 ffa07280 ace9bed8 2ad11d08\u001b[K\r\n\u001b[35m  R_b\u001b[0m\u001b[38;5;241m = k_b·G = \u001b[0ma6eb4979 aa4cea12 4e62b7f4 aa697910 0ecfe7b6 f505c7aa 40965eba 8201822a\u001b[K\r\n\u001b[33m  R  \u001b[0m\u001b[38;5;241m = R_a + R_b = \u001b[0ma91b6be9 7a497f8e c60df3c0 8869f2e7 0426d4da 676ae0a7 c7668579 35a80233\u001b[K\r\n\u001b[33m  r  \u001b[0m\u001b[38;5;241m = R.x mod n = \u001b[0ma91b6be9 7a497f8e c60df3c0 8869f2e7 0426d4da 676ae0a7 c7668579 35a80233\u001b[K\r\n\u001b[K\r\n\u001b[1m  ─── Oblivious Transfer \u001b[0m\u001b[38;5;241m──────────────────────────────────────────────────────────────────────────────────────────────\u001b[0m\u001b[K\r\n\u001b[38;5;241m  sender:   \u001b[0mx₀ = 36ff7b15 59495489 752691c3 c7c8332b…\u001b[38;5;241m  random\u001b[0m\u001b[K\r\n\u001b[38;5;241m            \u001b[0mx₁ = 27770f20 285cd1ec 4bbd3902 14bdc513…\u001b[38;5;241m  random\u001b[0m\u001b[K\r\n\u001b[38;5;241m  receiver: \u001b[0mc  = 0\u001b[K\r\n\u001b[38;5;241m            \u001b[0mx_c = 36ff7b15 59495489 752691c3 c7c8332b…\u001b[K\r\n\u001b[K\r\n\u001b[1m  ─── Multiplicative to Additive \u001b[0m\u001b[38;5;241m──────────────────────────────────────────────────────────────────────────────────────\u001b[0m\u001b[K\r\n\u001b[38;5;241m  product = k_a · k_b mod n\u001b[0m\u001b[K\r\n\u001b[38;5;241m  β ="]
