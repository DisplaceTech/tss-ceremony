[16.812619, "o", "\r\n=== Ceremony Complete ===\r\nPublic Key:  f9308a019258c31049344f85f89d5229b531c845836f99b08601f113bce036f9\r\nSignature R: a91b6be97a497f8ec60df3c08869f2e70426d4da676ae0a7c766857935a80233\r\nSignature S: 4a1967d8d1769d08e2833d7897cf179fc942685073f89ecebecb8f832d1b8b60\r\nMessage:     Hello, threshold signatures\r\n"]
[16.812748, "o", "\r\n=== Verify with OpenSSL ===\r\necho -n 'Hello, threshold signatures' | \\\r\n    openssl dgst -sha256 \\\r\n    -verify <(echo '3056301006072a8648ce3d020106052b8104000a03420004f9308a019258c31049344f85f89d5229b531c845836f99b08601f113bce036f9388f7b0f632de8140fe337e62a37f3566500a99934c2231b6cb9fd7584b8e672' | \\\r\n      xxd -r -p | openssl ec -pubin -inform DER 2>/dev/null) \\\r\n    -signature <(echo '3045022100a91b6be97a497f8ec60df3c08869f2e70426d4da676ae0a7c766857935a8023302204a1967d8d1769d08e2833d7897cf179fc942685073f89ecebecb8f832d1b8b60' | xxd -r -p)\r\n"]
